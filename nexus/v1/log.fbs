namespace muscat;

enum Muscat_Log_Level: byte {
    UNKNOWN = -1,
    INFO = 0,
    WARNING = 1,
    ERROR = 2,
    USER = 3,
    DEBUG = 4,
    GENERAL = 5,
}

table Muscat_Log {
    robot_model: string (required);
    level: Muscat_Log_Level;
    timestamp: string;
    contents: string (required);
}
