        - enabled       : 세이프티 범퍼 활성화 여부
        - bumper_state  : 세이프티 범퍼 상태
*/
table RequestCapabilitySafetyBumper {
}
table ResponseCapabilitySafetyBumper {
    enabled: bool;
    bumper_state: bool;
    //bumper_type: BumperTypeEnum;
}

/*
    category    :       RPC
    response    :       One-shot
    topic       :       {robotType}/capability/safetyInterlock
    usage       :       세이프티 인터락 기능 조회 ( 세이프티 인터락 기능 지원안하는 모델의 경우 queryable 하지 않음 )
    field
