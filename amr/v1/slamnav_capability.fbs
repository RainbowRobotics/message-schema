}

/*
    category    :       RPC
    response    :       One-shot
    topic       :       {robotType}/capability/tabos
    usage       :       TABOS 기능 조회 ( TABOS 기능 지원안하는 모델의 경우 queryable 하지 않음 )
    field
        - tabos_voltage   : TABOS 전압
        - tabos_current   : TABOS 전류
        - tabos_soc       : TABOS SOC
        - tabos_soh       : TABOS SOH
        - tabos_temp      : TABOS 온도
*/
table RequestCapabilityTabos {
}
