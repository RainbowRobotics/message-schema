        - interlock_state  : 세이프티 인터락 상태
*/
table RequestCapabilitySafetyInterlock {
}
table ResponseCapabilitySafetyInterlock {
    enabled: bool;
    interlock_state: bool;
}

/*
    category    :       RPC
    response    :       One-shot
    topic       :       {robotType}/capability/safetyObstacle
    usage       :       세이프티 장애물 기능 조회 ( 세이프티 장애물 기능 지원안하는 모델의 경우 queryable 하지 않음 )
    field
