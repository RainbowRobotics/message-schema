namespace SLAMNAV;

enum ResultEnum:byte { ACCEPT = 0, REJECT = 1 }

table ResponseResult {
  result: ResultEnum = ACCEPT;
}

table MultilingualStruct {
  ko: string;
  en: string (required);
  ja: string;
  zh: string;
  vi: string;
  th: string;
  es: string;
}

enum MuscatLogLevel: byte {
    UNKNOWN = -1,
    INFO = 0,
    WARNING = 1,
    ERROR = 2,
    USER = 3,
    DEBUG = 4,
    GENERAL = 5,
}
