namespace SLAMNAV;


// -------------------------------------------------
// -----------                              --------
// -----------          RPC(Query)          --------
// -----------                              --------
// -------------------------------------------------


/*
    category    :       RPC
    response    :       One-shot
    topic       :       {robotType}/multi/path
    usage       :       멀티 로봇 경로 설정
    field
        - path          :       노드 ID 리스트
        - preset	:	preset
*/
table RequestMultiPath {
    id: string;
    path: [string];
    preset: int;
}
table ResponseMultiPath {
    id: string;
    path: [string];
    preset: int;
    result: string;
    message: string;
}

/*
    category    :       RPC
    response    :       One-shot
    topic       :       {robotType}/multi/vobs
    usage       :       멀티 로봇 가상 장애물 설정
    field
        - vobs_robots_data      :       가상 장애물 로봇 목록
        - vobs_robots_column    :       data column ( "3" )
        - vobs_robots_row       :       data row ( vobs_robots_data size )
        - vobs_closures         :       가상 장애물 클로저 목록
        - is_vobs_c             :       클로저 변경 여부 ( true / false )
*/
table RequestMultiVobs {
    id: string;
    vobs_robots: [float];
    vobs_robots_column: uint32;
    vobs_robots_row: uint32;
    vobs_closures: [string];
    is_vobs_c: bool;
}
table ResponseMultiVobs {
    id: string;
    vobs_robots: [float];
    vobs_robots_column: uint32;
    vobs_robots_row: uint32;
    vobs_closures: [string];
    is_vobs_c: bool;
    result: string;
    message: string;
}
